generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  SUPERADMIN
}

// ─────────────────────────────────────────────
// STORE
// ─────────────────────────────────────────────

model Category {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  description  String?
  imageUrl     String?
  displayOrder Int       @default(0)
  products     Product[]
  createdAt    DateTime  @default(now())
}

model Product {
  id                   String      @id @default(cuid())
  name                 String
  slug                 String      @unique
  shortDescription     String?
  longDescription      String?
  // Json arrays (SQLite lacks String[]; maps to JSONB on PostgreSQL)
  images               Json        @default("[]")
  price                Float
  comparePrice         Float?
  tier                 Tier        @default(WOOD)
  tags                 Json        @default("[]")
  whatsIncluded        Json        @default("[]")
  stock                Int         @default(-1)
  featured             Boolean     @default(false)
  status               Status      @default(DRAFT)
  paymentLink          String?
  deliveryInstructions String?
  categoryId           String
  category             Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems           OrderItem[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

enum Tier {
  WOOD
  IRON
  GOLD
  DIAMOND
  NETHERITE
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  customerName    String
  customerEmail   String
  discordUsername String?
  items           OrderItem[]
  subtotal        Float
  discount        Float       @default(0)
  total           Float
  couponCode      String?
  coupon          Coupon?     @relation(fields: [couponCode], references: [code])
  status          OrderStatus @default(PENDING)
  stripeSessionId String?
  internalNotes   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  price     Float
}

enum OrderStatus {
  PENDING
  PROCESSING
  DELIVERED
  CANCELLED
}

// ─────────────────────────────────────────────
// COUPONS
// ─────────────────────────────────────────────

model Coupon {
  code          String      @id
  type          CouponType
  value         Float
  minOrderValue Float       @default(0)
  usageLimit    Int         @default(0)
  timesUsed     Int         @default(0)
  expiryDate    DateTime?
  active        Boolean     @default(true)
  orders        Order[]
  createdAt     DateTime    @default(now())
}

enum CouponType {
  PERCENTAGE
  FIXED
}

// ─────────────────────────────────────────────
// CMS
// ─────────────────────────────────────────────

model Banner {
  id           String   @id @default(cuid())
  title        String
  subtitle     String?
  imageUrl     String
  ctaText      String?
  ctaLink      String?
  active       Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  username  String
  avatarUrl String?
  review    String
  rating    Int      @default(5)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Faq {
  id           String   @id @default(cuid())
  question     String
  answer       String
  category     String   @default("General")
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
}

model SiteSettings {
  id                            String  @id @default("singleton")
  siteName                      String  @default("My Minecraft Store")
  tagline                       String?
  logoUrl                       String?
  faviconUrl                    String?
  currency                      String  @default("USD")
  contactEmail                  String?
  discordLink                   String?
  twitterLink                   String?
  youtubeLink                   String?
  instagramLink                 String?
  tiktokLink                    String?
  stripeEnabled                 Boolean @default(false)
  manualPaymentInstructions     String?
  defaultDeliveryInstructions   String?
  metaTitle                     String?
  metaDescription               String?
  ogImageUrl                    String?
}
