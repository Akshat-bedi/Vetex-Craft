# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"
# Production PostgreSQL: DATABASE_URL="postgresql://user:password@localhost:5432/minecraft_store"

# Seed script (optional — defaults shown)
SEED_ADMIN_EMAIL="admin@minecraftstore.local"
SEED_ADMIN_PASSWORD="Admin123!"

# Auth.js / NextAuth v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Legacy aliases (optional)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Stripe (optional)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Uploadthing (v7 uses token; legacy secret + app id also supported)
UPLOADTHING_TOKEN="..."
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="..."

# Resend (email)
RESEND_API_KEY="re_..."
FROM_EMAIL="orders@yourdomain.com"
